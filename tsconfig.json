{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "types": [
      "@cloudflare/workers-types",
      "vitest/globals",
      "@cloudflare/vitest-pool-workers"
    ]
  },
  "include": ["src", "frontend/src", "test"]
}
